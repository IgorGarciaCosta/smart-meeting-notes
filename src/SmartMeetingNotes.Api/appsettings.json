{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Whisper": {
    "Model": "medium",
    "Device": "cpu"
  },
  "DataPaths": {
    "Audio": "data/audio",
    "Meetings": "data/meetings"
  },
  "Upload": {
    "MaxFileSizeBytes": 209715200,
    "MaxChunkSizeBytes": 52428800,
    "MaxChunksPerMeeting": 60
  }
}
